  "defaultDefinition": {
    "key": "section-site",
    "websiteTypes": [],
    "navigationModes": [],
    "allowedSectionTypes": ["header", "hero", "profileIdentity", "actions", "richText", "links", "socialLinks", "cardGrid", "gallery", "faq", "contact", "contactForm", "blogFeed", "storeFeed", "digitalProductFeed", "bookingsFeed", "footer"],
    "supportsNavigation": true,
    "pageMode": "multi"
  },
  "bindings": {
    "sourceModes": ["manual", "shared", "collection", "query", "pick"],
    "defaultSourceMode": "manual",
    "description": "Section renderers read section.props; a backend resolver fills those props from content sources when sourceMode is shared/collection/query/pick."
  },
  "contentSources": {
    "profile": {
      "supports": ["shared"],
      "sharedKeys": [
        "site.identity",
        "site.contact",
        "site.location",
        "site.socialLinks",
        "site.links",
        "site.defaultContactForm"
      ]
    },
    "blog": {
      "model": "Post",
      "groupField": "category",
      "supports": ["manual", "query", "pick"],
      "queryKeys": ["category", "tag", "latest", "featured"]
    },
    "gallery": {
      "model": "GalleryItem",
      "groupField": "collectionId",
      "supports": ["manual", "collection", "pick"],
      "directory": "galleryCollection"
    },
    "faq": {
      "model": "QAItem",
      "groupField": "groupKey",
      "supports": ["manual", "collection", "pick"],
      "directory": "faqCollection"
    },
    "store": {
      "model": "Product",
      "groupField": "category",
      "supports": ["manual", "query", "pick"],
      "queryKeys": ["category", "latest", "featured"]
    },
    "digitalProducts": {
      "model": "DigitalProduct",
      "groupField": "category",
      "supports": ["manual", "query", "pick"],
      "queryKeys": ["category", "latest", "featured"]
    },
    "bookings": {
      "model": "BookingService",
      "groupField": "groupKey",
      "supports": ["manual", "collection", "pick"]
    },
    "links": {
      "model": "Link",
      "groupField": "collectionId",
      "supports": ["shared", "collection", "pick"],
      "directory": "linkCollection",
      "description": "First-class Link records. 'shared' returns all active links (falls back to legacy Profile.links[] during transition); 'collection' filters by LinkCollection slug; 'pick' selects specific Link._id values."
    },
    "formDefinition": {
      "model": "FormDefinition",
      "groupField": "name",
      "supports": ["shared", "collection"],
      "description": "Reusable contact/lead forms. 'shared' uses the profile default form; 'collection' picks a specific FormDefinition by id."
    },
    "galleryCollection": {
      "model": "GalleryCollection",
      "groupField": "slug",
      "supports": ["directory"],
      "description": "Managed catalog of named gallery collections. Its slugs populate GalleryItem.collectionId; the gallery feed's collection mode picks from this directory."
    },
    "faqCollection": {
      "model": "FAQCollection",
      "groupField": "slug",
      "supports": ["directory"],
      "description": "Managed catalog of named FAQ collections. Its slugs populate QAItem.groupKey; the faq section's collection mode picks from this directory."
    },
    "linkCollection": {
      "model": "LinkCollection",
      "groupField": "slug",
      "supports": ["directory"],
      "description": "Managed catalog of named link collections. Its slugs populate Profile.links[].collectionId; the links section's collection mode picks from this directory."
    }
  },
  "sectionSources": {
    "header": "profile",
    "blogFeed": "blog",
    "gallery": "gallery",
    "faq": "faq",
    "contact": "profile",
    "links": "links",
    "socialLinks": "profile",
    "profileIdentity": "profile",
    "contactForm": "formDefinition",
    "storeFeed": "store",
    "digitalProductFeed": "digitalProducts",
    "bookingsFeed": "bookings",
    "footer": "profile"
  }
}